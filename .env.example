# SkyLake Environment Configuration
# Copy this file to .env and fill in values
# Never commit .env to git

# ── Ingestion ──────────────────────────────────────────
# NOAA AWC API requires no key — no values needed here

# Target airports to monitor (comma-separated ICAO codes)
SKYLAKE_AIRPORTS=KJFK,KLAX,KORD,KATL,KDFW,KSEA,KDEN,KMIA

# ── Storage ────────────────────────────────────────────
SKYLAKE_DATA_DIR=./data
SKYLAKE_DUCKDB_PATH=./data/skylake.duckdb

# ── Dagster ────────────────────────────────────────────
DAGSTER_HOME=./dagster/dagster_home

# ── Soda ───────────────────────────────────────────────
SODA_CLOUD_API_KEY=

# ── Environment ────────────────────────────────────────
SKYLAKE_ENV=development
LOG_LEVEL=INFO
